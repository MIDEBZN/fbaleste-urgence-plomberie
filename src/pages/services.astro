---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppWidget from '../components/WhatsAppWidget.astro';

const title = "Nos Services de Plomberie & Chauffage à Bruxelles | Fbaleste";
const description = "Découvrez l'ensemble de nos services : débouchage, dépannage chaudière, recherche de fuite non destructive, traitement de l'eau et installation sanitaire.";
---

<Layout title={title} description={description}>
  <Header />
  
  <main class="page-content pt-top">
    <div class="container header-section text-center animate-fade-in">
      <h1>Notre <span class="highlight">Expertise</span></h1>
      <p>Des interventions garanties, réalisées par des plombiers chauffagistes certifiés.</p>
    </div>

    <div class="container mt-3 mb-3">
      <div class="services-grid">
        <a href="/depannage-urgence" class="service-card glass">
          <div class="icon-placeholder">🚨</div>
          <h2>Dépannage d'Urgence</h2>
          <p>Intervention 24/7 en moins de 30 minutes pour sécuriser et réparer vos fuites d'eau ou pannes majeures.</p>
          <span class="read-more">Découvrir →</span>
        </a>

        <a href="/debouchage" class="service-card glass">
          <div class="icon-placeholder">🚽</div>
          <h2>Débouchage</h2>
          <p>Curage haute pression et débouchage manuel de vos canalisations, WC, éviers et égouts.</p>
          <span class="read-more">Découvrir →</span>
        </a>

        <a href="/detection-fuite" class="service-card glass">
          <div class="icon-placeholder">🔍</div>
          <h2>Détection de Fuites</h2>
          <p>Recherche non destructive par caméra thermique et gaz traceur. Rapport agréé assurances.</p>
          <span class="read-more">Découvrir →</span>
        </a>

        <a href="/chauffage-chaudiere" class="service-card glass">
          <div class="icon-placeholder">🔥</div>
          <h2>Chauffage & Chaudières</h2>
          <p>Installation, entretien légal et réparation de vos chaudières et chauffe-eau toutes marques.</p>
          <span class="read-more">Découvrir →</span>
        </a>

        <a href="/installations-sanitaires" class="service-card glass">
          <div class="icon-placeholder">🚿</div>
          <h2>Installations Sanitaires</h2>
          <p>Rénovation de salle de bain, installation de WC suspendus, douches à l'italienne et robinetterie.</p>
          <span class="read-more">Découvrir →</span>
        </a>

        <a href="/traitement-eau" class="service-card glass">
          <div class="icon-placeholder">💧</div>
          <h2>Traitement de l'Eau</h2>
          <p>Protection contre le calcaire via l'installation d'adoucisseurs d'eau et de filtres professionnels.</p>
          <span class="read-more">Découvrir →</span>
        </a>
      </div>
    </div>
  </main>
  
  <WhatsAppWidget />
  <Footer />
</Layout>

<style>
  .pt-top {
    padding-top: 120px;
  }
  
  .header-section {
    margin-bottom: 3rem;
  }
  
  .header-section h1 {
    font-size: 3rem;
  }
  
  .highlight {
    color: var(--accent);
  }
  
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }
  
  .service-card {
    display: flex;
    flex-direction: column;
    padding: 2.5rem;
    border-radius: 16px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    text-decoration: none;
    color: inherit;
  }
  
  .service-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 40px 0 rgba(15, 76, 129, 0.15);
  }
  
  .icon-placeholder {
    font-size: 3rem;
    margin-bottom: 1rem;
  }
  
  .service-card h2 {
    font-size: 1.5rem;
    color: var(--primary);
    margin-bottom: 1rem;
  }
  
  .service-card p {
    color: var(--text-muted);
    flex-grow: 1;
    margin-bottom: 1.5rem;
  }
  
  .read-more {
    font-weight: 600;
    color: var(--accent);
    align-self: flex-start;
  }
</style>
