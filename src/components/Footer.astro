---
import TrustBanner from './TrustBanner.astro';
import GlobalContactForm from './GlobalContactForm.astro';
---
<GlobalContactForm />
<TrustBanner />
<footer class="footer">
  <div class="container footer-grid">
    <div class="footer-info">
      <img src="/logo.png" alt="Fbaleste Urgence Plomberie Logo" style="height: 60px; margin-bottom: 1rem;" />
      <p>Votre partenaire de confiance pour tous vos besoins en plomberie à Bruxelles. Intervention rapide, prix transparents et service de qualité.</p>
      <div class="certifications">
        <span class="badge">Agréé Assurances</span>
        <span class="badge">Intervention en < 1h</span>
      </div>
    </div>
    
    <div class="footer-links">
      <h4>Services</h4>
      <ul>
        <li><a href="/depannage-urgence">Plomberie d'Urgence</a></li>
        <li><a href="/debouchage">Débouchage Canalisation</a></li>
        <li><a href="/detection-fuite">Recherche de Fuite</a></li>
        <li><a href="/chauffage-chaudiere">Chauffagiste</a></li>
        <li><a href="/installations-sanitaires">Installations Sanitaires</a></li>
        <li><a href="/traitement-eau">Traitement de l'Eau</a></li>
        <li><a href="/blog">Blog & Conseils</a></li>
      </ul>
    </div>
    
    <div class="footer-contact">
      <h4>Contact</h4>
      <p><strong>Urgences 24/7 :</strong> <a href="tel:+32465767511">0465 76 75 11</a></p>
      <p><strong>Email :</strong> <a href="mailto:contact@urgenceplomberie.be">contact@urgenceplomberie.be</a></p>
      <p><strong>Adresse :</strong> <a href="https://maps.app.goo.gl/WW4tpxVLW8qVs56M6" target="_blank" rel="noopener noreferrer">Av. d'Auderghem 287, 1040 Etterbeek</a></p>
      <p><strong>Zones :</strong> Toute la région de Bruxelles-Capitale</p>
    </div>
  </div>
  
  <div class="container footer-zones" style="margin-bottom: 3rem; padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.1);">
    <h4 style="margin-bottom: 1rem; color: var(--white);">Nos Zones d'Intervention à Bruxelles</h4>
    <div style="display: flex; flex-wrap: wrap; gap: 0.8rem; font-size: 0.85rem;">
      <a href="/zones/plombier-bruxelles" class="zone-tag">Bruxelles (1000)</a>
      <a href="/zones/plombier-schaerbeek" class="zone-tag">Schaerbeek</a>
      <a href="/zones/plombier-etterbeek" class="zone-tag">Etterbeek</a>
      <a href="/zones/plombier-ixelles" class="zone-tag">Ixelles</a>
      <a href="/zones/plombier-saint-gilles" class="zone-tag">Saint-Gilles</a>
      <a href="/zones/plombier-saint-josse-ten-noode" class="zone-tag">Saint-Josse</a>
      <a href="/zones/plombier-anderlecht" class="zone-tag">Anderlecht</a>
      <a href="/zones/plombier-molenbeek-saint-jean" class="zone-tag">Molenbeek</a>
      <a href="/zones/plombier-koekelberg" class="zone-tag">Koekelberg</a>
      <a href="/zones/plombier-berchem-sainte-agathe" class="zone-tag">Berchem-Sainte-Agathe</a>
      <a href="/zones/plombier-ganshoren" class="zone-tag">Ganshoren</a>
      <a href="/zones/plombier-jette" class="zone-tag">Jette</a>
      <a href="/zones/plombier-evere" class="zone-tag">Evere</a>
      <a href="/zones/plombier-woluwe-saint-pierre" class="zone-tag">Woluwe-Saint-Pierre</a>
      <a href="/zones/plombier-auderghem" class="zone-tag">Auderghem</a>
      <a href="/zones/plombier-watermael-boitsfort" class="zone-tag">Watermael-Boitsfort</a>
      <a href="/zones/plombier-uccle" class="zone-tag">Uccle</a>
      <a href="/zones/plombier-forest" class="zone-tag">Forest</a>
      <a href="/zones/plombier-woluwe-saint-lambert" class="zone-tag">Woluwe-Saint-Lambert</a>
    </div>
  </div>
  
  <div class="footer-bottom text-center">
    <p>&copy; {new Date().getFullYear()} Fbaleste Urgence Plomberie. Tous droits réservés.</p>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--primary);
    color: var(--white);
    padding: 4rem 0 0 0;
  }
  
  .footer h3, .footer h4 {
    color: var(--white);
  }
  
  .footer-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 3rem;
    margin-bottom: 3rem;
  }
  
  .footer-links ul li {
    margin-bottom: 0.5rem;
  }
  
  .footer-links a {
    color: #cbd5e1;
    transition: color 0.3s ease;
  }
  
  .footer-links a:hover {
    color: var(--accent);
  }

  .footer-contact p {
    margin-bottom: 0.5rem;
    color: #cbd5e1;
  }
  
  .certifications {
    display: flex;
    gap: 1rem;
    margin-top: 1.5rem;
  }
  
  .badge {
    background: rgba(255,255,255,0.1);
    padding: 0.5rem 1rem;
    border-radius: 4px;
    font-size: 0.85rem;
    font-weight: 600;
  }
  
  .footer-bottom {
    background-color: var(--primary-dark);
    padding: 1.5rem 0;
    color: #94a3b8;
    font-size: 0.9rem;
  }
  
  .zone-tag {
    color: #cbd5e1;
    background: rgba(255,255,255,0.05);
    padding: 0.4rem 0.8rem;
    border-radius: 4px;
    transition: all 0.3s ease;
    text-decoration: none;
  }
  .zone-tag:hover {
    color: var(--white);
    background: var(--accent);
  }
</style>
