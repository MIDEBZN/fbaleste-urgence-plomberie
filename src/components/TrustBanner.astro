---
---
<div class="trust-banner-wrapper">
  <div class="container">
    <div class="trust-grid">
      <div class="trust-item">
        <span class="trust-icon">🛡️</span>
        <div class="trust-text">
          <h4>Agréé Assurances</h4>
          <p>Ethias, AXA, AG, Belfius...</p>
        </div>
      </div>
      <div class="trust-item">
        <span class="trust-icon">⭐</span>
        <div class="trust-text">
          <h4>+15 Ans d'Expérience</h4>
          <p>Artisan expert certifié</p>
        </div>
      </div>
      <div class="trust-item">
        <span class="trust-icon">📜</span>
        <div class="trust-text">
          <h4>Toutes Certifications</h4>
          <p>Cerga, G1/G2/G3, Cedicol, VCA</p>
        </div>
      </div>
      <div class="trust-item">
        <span class="trust-icon">🤝</span>
        <div class="trust-text">
          <h4>Service Garanti</h4>
          <p>Décennale & pièces garanties 2 ans</p>
        </div>
      </div>
      <div class="trust-item">
        <span class="trust-icon">⚡</span>
        <div class="trust-text">
          <h4>Intervention Rapide</h4>
          <p>Chez vous en moins de 30 min</p>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .trust-banner-wrapper {
    background-color: var(--white);
    padding: 3rem 0;
    margin-top: 4rem;
    border-top: 1px solid #e2e8f0;
    box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.03);
    position: relative;
    z-index: 10;
  }

  .trust-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem;
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: var(--bg-color);
    padding: 1rem 1.25rem;
    border-radius: 12px;
    flex: 1;
    min-width: 220px;
    border: 1px solid #e2e8f0;
    transition: transform 0.3s ease;
  }

  .trust-item:hover {
    transform: translateY(-3px);
    border-color: var(--primary);
    box-shadow: 0 4px 15px rgba(15, 76, 129, 0.05);
  }

  .trust-icon {
    font-size: 2rem;
  }

  .trust-text h4 {
    margin: 0 0 0.25rem 0;
    color: var(--primary);
    font-size: 0.95rem;
    font-weight: 700;
  }

  .trust-text p {
    margin: 0;
    font-size: 0.8rem;
    color: var(--text-muted);
  }
</style>
