---
interface Props {
	title?: string;
	description?: string;
  preloadImage?: string;
}

const { 
  title = "Fbaleste Urgence Plomberie | Dépannage Plombier Bruxelles", 
  description = "Fbaleste Urgence Plomberie est votre expert pour tout dépannage et réparation en plomberie. Intervention rapide garantie.",
  preloadImage
} = Astro.props;
import '../styles/global.css';

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://www.urgenceplomberie.be');

const schema = {
  "@context": "https://schema.org",
  "@type": ["Organization", "PlumbingService"],
  "name": "Fbaleste Urgence Plomberie",
  "url": Astro.site?.toString() || 'https://www.urgenceplomberie.be/',
  "logo": "https://www.urgenceplomberie.be/logo.png",
  "telephone": "+32465767511",
  "sameAs": [
    "https://maps.app.goo.gl/oGRZHeiCwteckNcG6",
    "https://www.linkedin.com/company/urgenceplomberie",
    "https://twitter.com/urgenceplomberie"
  ],
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Bruxelles",
    "addressCountry": "BE"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Services Catalog",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Dépannage Urgence Plomberie"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Réparation Fuite d'Eau"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Débouchage Canalisations"
        }
      }
    ]
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.9",
    "reviewCount": "512"
  }
};
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/logo.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Fbaleste Urgence Plomberie</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL} />
		
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={`${title} | Fbaleste Urgence Plomberie`} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL('/logo.png', Astro.site || 'https://www.urgenceplomberie.be')} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL} />
		<meta property="twitter:title" content={`${title} | Fbaleste Urgence Plomberie`} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={new URL('/logo.png', Astro.site || 'https://www.urgenceplomberie.be')} />

		<link rel="alternate" hreflang="fr-BE" href={canonicalURL} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Outfit:wght@400;700&display=swap" rel="stylesheet" />
		{preloadImage && <link rel="preload" href={preloadImage} as="image" />}
		<script type="application/ld+json" set:html={JSON.stringify(schema)} />
	</head>
	<body>
		<slot />
	</body>
</html>
